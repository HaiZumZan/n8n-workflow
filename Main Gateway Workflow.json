    {
      "parameters": {
        "jsCode": "// 1. Lấy mã từ AI Agent\nlet rawCode = $input.item.json.output || \"\";\n\n// 2. Làm sạch Markdown chung\nlet cleanCode = rawCode.replace(/```mermaid|```/gi, \"\").trim();\n\n// 3. Tách dòng và xử lý\n// Nếu AI trả về 1 cục văn bản, ta cố gắng tách nó theo các dấu hiệu danh sách\nlet lines = cleanCode\n    .replace(/([0-9]+\\.|•|\\*)\\s+/g, \"\\n$1 \") // Ép xuống dòng trước các mục 1. 2. hoặc dấu chấm\n    .split('\\n');\n\nlet processedLines = [];\nlet rootFound = false;\n\nfor (let i = 0; i < lines.length; i++) {\n    let line = lines[i].trim();\n    if (!line || line.toLowerCase() === \"mindmap\") continue;\n\n    // LÀM SẠCH TRIỆT ĐỂ KÝ TỰ LỖI GUITAR\n    // Xóa dấu sao **, dấu ngoặc đơn (), dấu xuyệt /, và dấu hai chấm :\n    let cleanText = line\n        .replace(/\\*\\*|\\_\\_/g, \"\")         // Xóa in đậm\n        .replace(/[\\(\\)\\/\\\\:]/g, \" \")      // Thay ( ) / \\ : bằng khoảng trắng\n        .replace(/•|\\*|^\\d+\\./g, \"\")       // Xóa ký hiệu đầu dòng\n        .trim();\n\n    if (cleanText.length === 0) continue;\n\n    // Cấu trúc lại thành Mindmap\n    if (!rootFound) {\n        // Dòng đầu tiên làm Root\n        processedLines.push(`  root((\"${cleanText}\"))`);\n        rootFound = true;\n    } else {\n        // Các dòng sau làm nhánh con (thụt lề 4 khoảng trắng)\n        // Giới hạn độ dài để tránh lỗi URL quá dài (Mermaid.ink giới hạn khoảng 2000 ký tự)\n        let shortText = cleanText.substring(0, 80) + (cleanText.length > 80 ? \"...\" : \"\");\n        processedLines.push(`    \"${shortText}\"`);\n    }\n}\n\n// 4. Lắp ghép\nlet finalCode = \"mindmap\\n\" + processedLines.join(\"\\n\");\n\n// 5. Mã hóa Base64\nlet base64 = Buffer.from(finalCode).toString('base64')\n    .replace(/\\+/g, '-')\n    .replace(/\\//g, '_')\n    .replace(/=+$/, '');\n\nreturn {\n    mermaid_base64: base64,\n    original_code: finalCode\n};"
      },
